{
  "expo": {
    "name": "MergeScouting",
    "slug": "MergeScouting",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mergescouting",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.papaya0.MergeScouting",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.papaya0.MergeScouting"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "publicPath": "/Scouting-App-2706",
      "build": {
        "publicPath": "/Scouting-App-2706/"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "googleScriptUrl": "https://script.google.com/macros/s/AKfycbzOHkiIuOLBMwVrhyEkRZKGQQt7me0wCgAifFsubsqRPfqvcxyA3_5ljX4wUAHaDhw1Cg/exec",
      "googleSpreadsheetId": "1yn8AWzlBnvPj40UPl7VlMy9lVT4MaksyLzJSbNyjc4E",
      "googleMatchSheetName": "Raw Data",
      "googlePitSheetName": "Pit Scouting Data",
      "eas": {
        "projectId": "08da1bd5-40fb-4911-abf6-b2bd6fc2fb15"
      }
    },
    "owner": "papaya0"
  }
}
